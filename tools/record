#!/usr/bin/env bash
# tools/record — capture SSS gameplay video + audio to MP4
#
# Usage:
#   tools/record [output.mp4]
#
# Output defaults to recordings/sss_YYYYMMDD_HHMMSS.mp4 in the repo root.
# Press Ctrl+C to stop recording.
#
# Wayland (KDE Plasma): uses wl-screenrec via PipeWire.
#   A screen/window picker will appear when you start recording.
#   Requires: wl-screenrec  (sudo dnf install wl-screenrec)
#
# X11 / XWayland: uses ffmpeg x11grab. Launch the game first.
#   Requires: ffmpeg xdotool pactl
#   To force X11 mode on a Wayland session: SDL_VIDEODRIVER=x11 ./builds/sss

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
OUTPUT="${1:-$REPO_ROOT/recordings/sss_$(date +%Y%m%d_%H%M%S).mp4}"
mkdir -p "$(dirname "$OUTPUT")"

# --- detect display server ---
if [[ "${XDG_SESSION_TYPE:-}" == "wayland" ]] || [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    SESSION=wayland
else
    SESSION=x11
fi

# ============================================================
# Wayland path — wl-screenrec via PipeWire
# ============================================================
if [[ "$SESSION" == "wayland" ]]; then
    if command -v wl-screenrec &>/dev/null; then
        echo "Wayland session — a screen/window picker will appear"
        echo "Output: $OUTPUT"
        echo "Press Ctrl+C to stop."
        echo ""
        wl-screenrec --audio -f "$OUTPUT"
        echo ""
        echo "Saved: $OUTPUT"
        exit 0
    fi
    # wl-screenrec not available — fall through to X11 path via XWayland.
    # The game must be launched with: SDL_VIDEODRIVER=x11 ./builds/sss
    echo "note: Wayland session; using XWayland capture (SDL_VIDEODRIVER=x11 required for game)"
    echo ""
fi

# ============================================================
# X11 path — ffmpeg x11grab
# ============================================================
missing=()
for cmd in ffmpeg xdotool pactl; do
    command -v "$cmd" &>/dev/null || missing+=("$cmd")
done
if [[ ${#missing[@]} -gt 0 ]]; then
    echo "error: missing dependencies: ${missing[*]}" >&2
    echo "  Install with: sudo dnf install ${missing[*]}" >&2
    exit 1
fi

# Find game process
PID=$(pgrep -x sss 2>/dev/null | head -1 || true)
if [[ -z "$PID" ]]; then
    echo "error: sss is not running — launch the game first" >&2
    exit 1
fi

# QB64-PE (SDL2) doesn't set _NET_WM_PID; fall back to class/name search
WINDOW_ID=$(xdotool search --pid "$PID" 2>/dev/null | head -1 \
         || xdotool search --classname sss 2>/dev/null | head -1 \
         || xdotool search --name sss 2>/dev/null | head -1 \
         || true)
if [[ -z "$WINDOW_ID" ]]; then
    echo "error: could not find sss window" >&2
    echo "  If you're on Wayland, try: SDL_VIDEODRIVER=x11 ./builds/sss" >&2
    exit 1
fi

eval "$(xdotool getwindowgeometry --shell "$WINDOW_ID")"
echo "Window: ${WIDTH}x${HEIGHT} at ${X},${Y} (pid $PID)"

# Find audio monitor
MONITOR=$(pactl list sources short 2>/dev/null | awk '/monitor/ {print $2; exit}' || true)
if [[ -z "$MONITOR" ]]; then
    echo "warning: no audio monitor source found — recording video only"
    AUDIO_FLAGS=()
else
    echo "Audio:  $MONITOR"
    AUDIO_FLAGS=(-f pulse -i "$MONITOR")
fi

echo "Output: $OUTPUT"
echo "Press Ctrl+C to stop."
echo ""

# Upscale to 4x native (1280x960) with nearest-neighbor for crisp pixels
ffmpeg -y \
    -f x11grab -r 60 -video_size "${WIDTH}x${HEIGHT}" -i ":0.0+${X},${Y}" \
    "${AUDIO_FLAGS[@]}" \
    -vf "scale=1280:960:flags=neighbor" \
    -c:v libx264 -preset fast -crf 18 \
    -c:a aac -b:a 192k \
    -pix_fmt yuv420p \
    "$OUTPUT"

echo ""
echo "Saved: $OUTPUT"
