#!/bin/bash

if [ ! -f "$1" ]; then
    echo "Error: source file '$1' not found" >&2
    exit 1
fi

base=$(basename "$1" .bas)
old_exe="./builds/$base"

if [ "$1" == "sss.bas" ]; then
    echo ">>> Baking in-game spoken text..."
    "$(dirname "$0")/bake_speech_dict" || exit 1
    echo ">>> ...done!"
fi

# QB64-PE resolves $EMBED paths relative to its binary directory.
# Create assets -> repo/assets there so '$EMBED:assets/...' works
# regardless of where qb64pe is installed or where the repo lives.
QB64_BIN=$(which qb64pe 2>/dev/null)
if [ -z "$QB64_BIN" ]; then
    echo "Error: qb64pe not found in PATH" >&2
    exit 1
fi
ln -sfn "$(realpath .)/assets" "$(dirname "$(realpath "$QB64_BIN")")/assets"

# Remove stale executable so a failed build can't be mistaken for success
rm -f "$old_exe"
echo ">>> Building $1..."
build_output=$(qb64pe -s:ExeDefaultDir=./builds -w -x "$1" 2>&1)

build_status=$?
echo "$build_output"

if [ $build_status -ne 0 ] || echo "$build_output" | grep -Eiq 'error|fatal' || [ ! -x "$old_exe" ]; then
    echo "Error: build failed for '$base'" >&2
    exit 1
fi

echo ">>> done!"

if [ "$2" == "/run" ]; then
    "$old_exe" "${@:3}"
fi