#!/bin/bash

if [ ! -f "$1" ]; then
    echo "Error: source file '$1' not found" >&2
    exit 1
fi

base=$(basename "$1" .bas)
old_exe="./builds/$base"

if [ "$1" == "sss.bas" ]; then
    echo ">>> Baking in-game spoken text..."
    "$(dirname "$0")/bake_speech_dict" || exit 1
    echo ">>> ...done!"
    # Ensure assets/.env exists for $EMBED (empty = no network telemetry)
    if [ ! -f assets/.env ]; then
        touch assets/.env
    fi
    REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
    if ! git -C "$REPO_ROOT" diff --exit-code assets/speech_dict.txt > /dev/null 2>&1; then
        echo ""
        echo "!!! speech_dict.txt was stale and has been updated." >&2
        echo "!!! You must commit it before pushing:" >&2
        echo "!!!   git add assets/speech_dict.txt && git commit" >&2
        echo ""
    fi
fi

# QB64-PE resolves $EMBED paths relative to its binary directory.
# Create assets -> repo/assets there so '$EMBED:assets/...' works
# regardless of where qb64pe is installed or where the repo lives.
QB64_BIN=$(which qb64pe 2>/dev/null)
if [ -z "$QB64_BIN" ]; then
    echo "Error: qb64pe not found in PATH" >&2
    exit 1
fi
QB64_DIR="$(dirname "$(realpath "$QB64_BIN")")"
ln -sfn "$(realpath .)/assets" "$QB64_DIR/assets"

# Symlink libcurl.so into QB64_DIR so QB64-PE bakes ./libcurl.so (relative path).
# buildqb then copies the versioned .so.4 into builds/ so dlopen finds it at runtime.
if [ "$(uname -s)" = "Linux" ]; then
    CURL_SO=$(find /usr/lib64 /usr/lib -name 'libcurl.so' 2>/dev/null | head -1)
    if [ -n "$CURL_SO" ]; then
        ln -sf "$CURL_SO" "$QB64_DIR/libcurl.so"
    fi
fi


# Remove stale executable so a failed build can't be mistaken for success
rm -f "$old_exe"
echo ">>> Building $1..."
build_output=$(qb64pe -s:ExeDefaultDir=./builds -w -x "$1" 2>&1)

build_status=$?
echo "$build_output"

if [ $build_status -ne 0 ] || echo "$build_output" | grep -Eiq 'error|fatal' || [ ! -x "$old_exe" ]; then
    echo "Error: build failed for '$base'" >&2
    exit 1
fi

echo ">>> done!"

# Bundle libcurl.so into builds/ so dlopen("./libcurl.so") resolves at runtime.
# Users run the game from builds/ (or a wrapper script handles the cd).
if [ "$(uname -s)" = "Linux" ]; then
    CURL_RT=$(find /usr/lib64 /usr/lib -name 'libcurl.so.4' 2>/dev/null | head -1)
    if [ -n "$CURL_RT" ]; then
        cp "$CURL_RT" "./builds/libcurl.so"
    fi
fi

if [ "$2" == "/run" ]; then
    "$old_exe" "${@:3}"
fi