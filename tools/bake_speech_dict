#!/bin/bash
# bake_speech_dict — extract CMU phoneme entries needed for SSS game speech
# Run from repo root: bash tools/bake_speech_dict
set -e

DICT="assets/cmudict-0.txt"
OUT="assets/speech_dict.txt"
TMP="$(mktemp)"

# ---- render gametext.txt with token substitution applied ----
# Load gamevalues.ini into bash associative array, substitute into gametext.txt,
# then extract words — same order GTEXT_Render$ uses at runtime.
declare -A TOKENS
while IFS='=' read -r key val; do
    [[ -z "$key" || "${key:0:1}" == ";" || "${key:0:1}" == " " ]] && continue
    TOKENS["$key"]="$val"
done < assets/gamevalues.ini

rendered=$(cat assets/gametext.txt)
for key in "${!TOKENS[@]}"; do
    rendered="${rendered//\{\{$key\}\}/${TOKENS[$key]}}"
done

# Strip block tags, color codes, then apply the same contraction pre-pass
# SPK_Say uses at runtime: strip possessive 's, then bare apostrophes.
# This ensures "don't" -> "DONT" (not "DON"+"T") so missing entries fail here.
printf '%s\n' "$rendered" \
    | sed "s/\[BLOCK:[^]]*\]//g; s/~[0-9A-Fa-f]//g; s/'[Ss]//g; s/'//g" \
    | tr -cs 'A-Za-z' '\n' | tr 'a-z' 'A-Z' \
    | sort -u | grep -v '^$' > "$TMP"

total=$(wc -l < "$TMP")

# ---- extract matching entries from CMU dict ----
DATATMP="$(mktemp)"
found=0
while IFS= read -r word; do
    entry=$(grep "^${word} " "$DICT" | head -1)
    if [ -n "$entry" ]; then
        phones="${entry#* }"
        printf '%s %s\n' "$word" "$phones"
        found=$((found + 1))
    fi
done < "$TMP" > "$DATATMP"
sort -k1,1 "$DATATMP" -o "$DATATMP"

# ---- merge custom entries (alien names etc. not in CMU) ----
CUSTOM="assets/custom_words.txt"
custWord=0
if [ -f "$CUSTOM" ]; then
  custWord=$(grep -v '^#\|^$' "$CUSTOM" | wc -l)
  grep -v '^#\|^$' "$CUSTOM" >> "$DATATMP"
  sort -k1,1 "$DATATMP" -o "$DATATMP"
fi

# ---- find words with no pronunciation entry at all ----
FOUNDTMP="$(mktemp)"
cut -d' ' -f1 "$DATATMP" | sort > "$FOUNDTMP"
missing=$(comm -23 "$TMP" "$FOUNDTMP")
rm -f "$FOUNDTMP"

{
  printf '# SSS speech phoneme dictionary\n'
  printf '# Generated by bake_speech_dict\n'
  printf '\n'
  cat "$DATATMP"
  printf '\n# %d / %d words found in CMU dict (plus %d custom entries)\n' "$found" "$total" "$custWord"
} > "$OUT"

rm -f "$DATATMP" "$TMP"
echo "Wrote $OUT  ($(grep -vc '^#\|^$' "$OUT") entries)"

if [ -n "$missing" ]; then
  echo "" >&2
  echo "ERROR: the following words have no pronunciation entry." >&2
  echo "Add them to assets/custom_words.txt and re-run." >&2
  echo "" >&2
  printf '  %s\n' $missing >&2
  exit 1
fi
